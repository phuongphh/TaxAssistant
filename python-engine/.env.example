# ============================
# Application
# ============================
ENVIRONMENT=development
DEBUG=true

# ============================
# Server
# ============================
REST_HOST=0.0.0.0
REST_PORT=8000
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# ============================
# Database
# ============================
POSTGRES_URL=postgresql+asyncpg://taxapp:taxapp_dev@localhost:5432/taxassistant

# ============================
# Redis
# ============================
REDIS_URL=redis://localhost:6379

# ============================
# LLM / AI
# ============================
# Provider: "anthropic" or "openai_compatible"
LLM_PROVIDER=openai_compatible
LLM_MODEL=glm-5
LLM_TEMPERATURE=0.3
EMBEDDING_MODEL=voyage-multilingual-2

# --- Anthropic (when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- OpenAI-compatible / Z.AI (when LLM_PROVIDER=openai_compatible) ---
# Get your API key at: https://z.ai/model-api
OPENAI_API_KEY=your_zai_api_key
OPENAI_BASE_URL=https://api.z.ai/api/paas/v4/

# --- Voyage AI (Embeddings) ---
# Get your free API key at: https://dash.voyageai.com
# Free tier: 50M tokens/month
VOYAGE_API_KEY=your_voyage_api_key

# ============================
# ChromaDB (Vector Store)
# ============================
CHROMA_PERSIST_DIR=./data/chroma

# ============================
# Document Processing
# ============================
TESSERACT_LANG=vie
MAX_UPLOAD_SIZE_MB=10
