{
  "name": "tax-assistant-gateway",
  "version": "0.1.0",
  "description": "Node.js Gateway for Tax Assistant - handles messaging platforms, session management, and routing",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "proto:gen": "grpc_tools_node_protoc --ts_out=./src/grpc/generated --grpc_out=./src/grpc/generated --plugin=protoc-gen-grpc=./node_modules/.bin/grpc_tools_node_protoc_plugin -I ../proto ../proto/tax_service.proto",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.12",
    "express": "^4.18.2",
    "telegraf": "^4.16.0",
    "ioredis": "^5.3.2",
    "pg": "^8.12.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.2.0",
    "rate-limit-redis": "^4.2.0",
    "uuid": "^9.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
