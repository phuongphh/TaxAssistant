# ============================
# Application
# ============================
NODE_ENV=development
PORT=3000
WEBHOOK_PORT=3001

# ============================
# Telegram Bot
# ============================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# ============================
# Zalo OA (Official Account)
# ============================
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret
ZALO_OA_ACCESS_TOKEN=your_zalo_oa_access_token
ZALO_OA_REFRESH_TOKEN=your_zalo_oa_refresh_token
ZALO_WEBHOOK_SECRET=your_zalo_webhook_secret

# ============================
# Redis
# ============================
REDIS_URL=redis://localhost:6379

# ============================
# PostgreSQL
# ============================
POSTGRES_URL=postgresql://taxapp:taxapp_dev@localhost:5432/taxassistant

# ============================
# Python Tax Engine
# ============================
PYTHON_GRPC_HOST=localhost
PYTHON_GRPC_PORT=50051
PYTHON_REST_URL=http://localhost:8000

# ============================
# Rate Limiting
# ============================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ============================
# Session
# ============================
SESSION_TTL_SECONDS=3600
